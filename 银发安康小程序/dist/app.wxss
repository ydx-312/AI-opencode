button,checkbox,image,input,label,navigator,page,picker,radio,scroll-view,slider,swiper,switch,text,textarea,view{box-sizing:border-box;margin:0;padding:0}page{background-color:#f5f5f5;color:#212121;font-family:-apple-system,BlinkMacSystemFont,PingFang SC,Helvetica Neue,Microsoft YaHei,sans-serif;font-size:16rpx;line-height:1.6}.page{flex:1;margin:0 auto;max-width:800rpx;padding-bottom:80rpx;padding-left:16rpx;padding-right:16rpx;width:100%}.page-header{padding:16rpx 0;text-align:center}.page-title{color:#212121;font-size:24rpx;font-weight:700}.page-subtitle{color:#616161;font-size:16rpx;margin-top:4rpx}.card{background:#fff;border-radius:12rpx;box-shadow:0 1rpx 3rpx rgba(0,0,0,.12);margin-bottom:16rpx;padding:16rpx}.card-title{color:#212121;font-size:18rpx;font-weight:600;margin-bottom:12rpx}.section{margin-bottom:24rpx}.section-title{border-left:4rpx solid #2e7d32;color:#1b5e20;font-size:18rpx;font-weight:600;margin-bottom:12rpx;padding-left:12rpx}.form-group{margin-bottom:16rpx}.form-label{color:#212121;display:block;font-size:16rpx;font-weight:500;margin-bottom:8rpx}.form-input{background:#fff;border:2rpx solid #e0e0e0;border-radius:8rpx;color:#212121;font-size:18rpx;min-height:48rpx;padding:12rpx 16rpx;width:100%}.tag{align-items:center;border-radius:20rpx;display:inline-flex;font-size:14rpx;font-weight:500;padding:4rpx 12rpx}.tag-primary{background:#e8f5e9;color:#2e7d32}.tag-warning{background:#fff3e0;color:#ff8f00}.tag-info{background:#e3f2fd;color:#1976d2}.tag-danger{background:#ffebee;color:#d32f2f}.empty-state{color:#9e9e9e;padding:32rpx 16rpx;text-align:center}.empty-state-icon{font-size:48rpx;margin-bottom:16rpx}.empty-state-text{font-size:16rpx}.loading{align-items:center;display:flex;justify-content:center;padding:32rpx}.spinner{animation:spin .8s linear infinite;border:3rpx solid #e0e0e0;border-radius:50%;border-top-color:#2e7d32;height:32rpx;width:32rpx}@keyframes spin{to{transform:rotate(1turn)}}